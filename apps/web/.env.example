# Contact card configuration (safe to commit)
# ==========================================
#
# Put real values in `apps/web/.env.local` (recommended) or set them in your hosting provider.
# This project intentionally reads contact details from env so nothing sensitive is committed.
#
# Tip: Use the local editor at `/edit` to generate a valid env file.
#
# Local preview (optional)
# ------------------------
# By default, contact items are hidden in development.
# Set this to `true` to preview locally:
CONTACT_RENDER_IN_DEV=false

# Public URL (recommended)
# ------------------------
# Used to generate absolute QR codes + the vCard download URL.
CONTACT_PUBLIC_URL=https://contact.example.com

# Page metadata (optional)
# ------------------------
# The page still sends strong "do not index" signals.
CONTACT_PAGE_TITLE=Contact
CONTACT_PAGE_DESCRIPTION=A simple private contact card.

# Profile (UI header)
# -------------------
CONTACT_DISPLAY_NAME=Your Name
CONTACT_HEADLINE=A short tagline
CONTACT_BIO=A slightly longer bio
CONTACT_AVATAR_URL=https://example.com/avatar.jpg

# Contact items (buttons)
# -----------------------
# Minecraft server.properties style: one line per platform.
#
# Examples:
#   INSTAGRAM=hellobubles1233
#   GITHUB=Hellobubles1233
#   DISCORD_USER_ID=000000000000000000
#   MASTODON_USERNAME=alice
#   MASTODON_SERVER=mastodon.social
#
# Optional per-item fields:
#   <KEY>_LABEL, <KEY>_SUBTITLE, <KEY>_ORDER, <KEY>_NEWTAB, <KEY>_URL
# Multiple entries per platform:
#   EMAIL_2=you@work.example
#   EMAIL_2_LABEL=Work
#
# Direct
EMAIL=
PHONE=
SMS=
WHATSAPP=
TELEGRAM=
SIGNAL=
DISCORD_USER_ID=
MATRIX_ID=
#
# Developer
GITHUB=
GITLAB=
CODEPEN=
DEVTO=
KEYBASE=
#
# Social
LINKEDIN=
X=
INSTAGRAM=
THREADS=
TIKTOK=
SNAPCHAT=
REDDIT=
BLUESKY=
MASTODON_USERNAME=
MASTODON_SERVER=
FACEBOOK=
STEAM=
#
# Creator
YOUTUBE=
TWITCH=
BEHANCE=
DRIBBBLE=
MEDIUM=
PINTEREST=
SUBSTACK_SUBDOMAIN=
PATREON=
KOFI=
BUYMEACOFFEE=
SPOTIFY=
#
# General
WEBSITE=
CALENDAR=
LOCATION=
LINK=
COPY=

# Custom items (optional, repeat by incrementing number)
# -----------------------------------------------------
# ITEM_1_TYPE=link
# ITEM_1_LABEL=Other
# ITEM_1_VALUE=https://example.com
# ITEM_1_EXTRA=
# ITEM_1_URL=

