VCARD_KIND=
VCARD_UID=
VCARD_GIVEN=
VCARD_FAMILY=
VCARD_ADDITIONAL=
VCARD_PREFIX=
VCARD_SUFFIX=
VCARD_NICKNAMES=
VCARD_ORG=
VCARD_TITLE=
VCARD_ROLE=
VCARD_NOTE=
VCARD_CATEGORIES=
