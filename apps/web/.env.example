# Media
VCARD_PHOTO_URI=
VCARD_PHOTO_MEDIATYPE=
VCARD_LOGO_URI=
VCARD_LOGO_MEDIATYPE=
#
# Typed values (repeat by incrementing number)
VCARD_EMAIL_1=
VCARD_EMAIL_1_TYPE=
VCARD_EMAIL_1_PREF=
VCARD_EMAIL_1_LABEL=
VCARD_TEL_1=
VCARD_TEL_1_TYPE=
VCARD_TEL_1_PREF=
VCARD_TEL_1_LABEL=
VCARD_URL_1=
VCARD_URL_1_TYPE=
VCARD_URL_1_PREF=
VCARD_URL_1_LABEL=
VCARD_IMPP_1=
VCARD_IMPP_1_TYPE=
VCARD_IMPP_1_PREF=
VCARD_IMPP_1_LABEL=
#
# Addresses (repeat by incrementing number)
VCARD_ADR_1_STREET=
VCARD_ADR_1_LOCALITY=
VCARD_ADR_1_REGION=
VCARD_ADR_1_POSTAL_CODE=
VCARD_ADR_1_COUNTRY=
VCARD_ADR_1_POBOX=
VCARD_ADR_1_EXTENDED=
