# Advanced JSON (optional)
# ------------------------
# If set, these override the flat properties format above.
CONTACT_PROFILE_JSON=
CONTACT_ITEMS_JSON=
CONTACT_VCARD_JSON=
CONTACT_CONFIG_JSON=

# Security note
# -------------
# robots.txt + noindex headers are strong signals, not access control.
# Anyone with the link can still access the data.
